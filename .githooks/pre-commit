#!/usr/bin/env sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

originally_staged=$(git diff --cached --name-only)

just fmt

# Re-stage only the files that were originally staged (not all tracked modifications)
if [ -n "$originally_staged" ]; then
    printf '%s\n' "$originally_staged" | while IFS= read -r f; do
        git add -- "$f"
    done
fi

just lint

staged=$(git diff --cached --name-only)

# Rust: slow (~25s), only run when Rust/TOML/lockfile changed
if echo "$staged" | grep -qE '\.(rs|toml)$|Cargo\.lock'; then
    just test unit-rust
fi

# JS SDK
if echo "$staged" | grep -qE '^sdk/javascript/'; then
    just test unit-js
fi

# Go SDK
if echo "$staged" | grep -qE '^sdk/go/|^examples/go/'; then
    just test unit-go
fi

# Typecheck, build, and link-check website if website files changed
if echo "$staged" | grep -q '^website/'; then
    if ! command -v lychee >/dev/null 2>&1; then
        echo "error: lychee not installed, required for website link check (brew install lychee)" >&2
        exit 1
    fi
    just check::website
fi
