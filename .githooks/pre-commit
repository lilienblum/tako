#!/usr/bin/env sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

just fmt
git add -u
just lint

# Check for broken links if website files changed
if git diff --cached --name-only | grep -q '^website/'; then
    if command -v lychee >/dev/null 2>&1; then
        just links
    else
        echo "warning: lychee not installed, skipping link check (brew install lychee)" >&2
    fi
fi
