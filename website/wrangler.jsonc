{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tako-website",
  "main": "src/worker.ts",
  "compatibility_date": "2026-01-29",
  "workers_dev": false,
  "preview_urls": true,
  "routes": [
    {
      "pattern": "tako.sh",
      "custom_domain": true,
    },
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": true,
    "not_found_handling": "404-page",
  },
}
