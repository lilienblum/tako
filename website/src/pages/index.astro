---
import BaseLayout from "../layouts/BaseLayout.astro";
import CopyButton from "../components/CopyButton.astro";
---
<BaseLayout
  title="Tako | Ship it like FTP"
  description="Deploy Node.js, Bun, and Deno apps to your own servers with rolling deploys, health checks, TLS, logs, and secrets. Tako is a self-hosted alternative to managed PaaS platforms."
>
  <link slot="head" rel="preload" as="image" href="/assets/hero-garden.webp" />
  <section class="hero">
    <div
      class="panel-hanger"
      id="mit-hanger"
      aria-label="License: MIT (includes Apache-2.0 dependencies)"
      title="Project code is MIT; some dependencies (for example Pingora) are Apache-2.0. See THIRD_PARTY_NOTICES.md."
    >
      <span class="panel-pin" id="mit-pin" aria-hidden="true"></span>
      <div class="panel-arm">
        <span class="panel-thread"></span>
        <div class="panel-tag" id="mit-tag">
          <span class="panel-tag-label">license</span>
          <span class="panel-tag-value">MIT</span>
        </div>
      </div>
    </div>
    <h1 class="title">Your servers<br />were <span class="swirl">fine</span><br />all along.</h1>
    <p class="subtitle">
      Development to production and everything in between &mdash; one tool, your servers
    </p>

    <div class="command-card">
      <div class="command-head">
        <div class="command-title">install</div>
      </div>
      <div class="command-body">
        <span class="prompt">$</span>
        <span class="cmd" id="typed-cmd"></span>
        <span class="cursor" aria-hidden="true"></span>
        <CopyButton class="copy-inline" id="copy" ariaLabel="copy install command" title="copy install command" label="copy install command" />
      </div>
      <div class="command-actions">
        <a class="btn" href="/docs">read the docs</a>
        <div class="command-selector" role="group" aria-label="Install command type">
          <button class="command-mode is-active" data-install-mode="shell" type="button">shell</button>
          <button class="command-mode" data-install-mode="cargo" type="button">cargo</button>
        </div>
      </div>
    </div>
    <div class="hero-mobile-cta">
      <a href="/docs/quickstart" class="btn cta-btn">get started</a>
      <a href="/docs" class="cta-link">or read the docs &rarr;</a>
    </div>
  </section>

  <section class="workflow-section">
    <div class="hero-block-head">
      <h2 class="hero-block-label">Three commands and you're live</h2>
      <span class="hero-block-rule" aria-hidden="true"></span>
    </div>
    <ol class="workflow-steps">
      <li class="workflow-step">
        <a href="/docs/quickstart" class="workflow-link">
          <div class="workflow-visual">
            <span class="workflow-orb workflow-orb-1" aria-hidden="true">1</span>
            <img src="/assets/step-init.webp" alt="" class="workflow-img" width="120" height="120" loading="lazy" />
          </div>
          <code class="workflow-cmd">tako init</code>
          <p class="workflow-desc">Detect runtime, create config</p>
        </a>
      </li>
      <li class="workflow-step">
        <a href="/docs/development" class="workflow-link">
          <div class="workflow-visual">
            <span class="workflow-orb workflow-orb-2" aria-hidden="true">2</span>
            <img src="/assets/step-dev.webp" alt="" class="workflow-img" width="120" height="120" loading="lazy" />
          </div>
          <code class="workflow-cmd">tako dev</code>
          <p class="workflow-desc">Develop locally with HTTPS</p>
        </a>
      </li>
      <li class="workflow-step">
        <a href="/docs/deployment" class="workflow-link">
          <div class="workflow-visual">
            <span class="workflow-orb workflow-orb-3" aria-hidden="true">3</span>
            <img src="/assets/step-deploy.webp" alt="" class="workflow-img" width="120" height="120" loading="lazy" />
          </div>
          <code class="workflow-cmd">tako deploy</code>
          <p class="workflow-desc">Build, upload, rolling update</p>
        </a>
      </li>
    </ol>
  </section>

  <section class="features-section">
    <div class="hero-block-head">
      <h2 class="hero-block-label">What Tako handles for you</h2>
      <span class="hero-block-rule" aria-hidden="true"></span>
    </div>
    <div class="feature-list">
      <a href="/docs/tako-toml" class="feature-link">
        <span class="feature-link-title">Highly opinionated</span>
        <span class="feature-link-desc">Is it <code>dev</code> or <code>development</code>? Tako already decided. You just ship</span>
      </a>
      <a href="/docs/deployment" class="feature-link">
        <span class="feature-link-title">Rolling deploys</span>
        <span class="feature-link-desc">New instances come up first, traffic shifts after health checks pass</span>
      </a>
      <a href="/docs/how-tako-works#health-checks-and-instance-lifecycle" class="feature-link">
        <span class="feature-link-title">Health-based routing</span>
        <span class="feature-link-desc">Degraded instances lose traffic in seconds, no manual intervention</span>
      </a>
      <a href="/docs/cli" class="feature-link">
        <span class="feature-link-title">Logs, status, secrets</span>
        <span class="feature-link-desc">Inspect what's running, manage secrets, check history &mdash; all from the CLI</span>
      </a>
      <a href="/docs/how-tako-works#scaling" class="feature-link">
        <span class="feature-link-title">Scale to zero and back</span>
        <span class="feature-link-desc">Idle apps sleep, the next request wakes them up</span>
      </a>
      <a href="/docs/how-tako-works#tls-and-certificates" class="feature-link">
        <span class="feature-link-title">Automatic TLS</span>
        <span class="feature-link-desc">Let's Encrypt in production, local CA in dev &mdash; zero config</span>
      </a>
      <a href="/docs/how-tako-works#rolling-updates" class="feature-link">
        <span class="feature-link-title">Instant rollback</span>
        <span class="feature-link-desc">Previous version stays ready, one command to revert</span>
      </a>
      <a href="/docs/presets" class="feature-link">
        <span class="feature-link-title">Impatient by default</span>
        <span class="feature-link-desc">Presets tuned for fast builds &mdash; deploy in seconds</span>
      </a>
      <a href="/docs/development" class="feature-link">
        <span class="feature-link-title">Agent-friendly</span>
        <span class="feature-link-desc">Each worktree gets its own URL &mdash; <code>myapp-fix69.tako.test</code></span>
      </a>
      <a href="/docs/how-tako-works" class="feature-link">
        <span class="feature-link-title">Bun, Node, Go &mdash; you name it</span>
        <span class="feature-link-desc">Auto-detected runtimes, more coming soon</span>
      </a>
    </div>
  </section>

  <section class="cta-section">
    <p class="cta-text">Your servers are waiting.</p>
    <div class="cta-actions">
      <a href="/docs/quickstart" class="btn cta-btn">get started</a>
      <a href="/docs/how-tako-works" class="cta-link">or read how Tako works &rarr;</a>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .hero {
    border-radius: var(--panel-radius);
    border: 2px solid var(--line);
    background: rgba(255, 255, 255, 0.8);
    box-shadow: 0 18px 45px rgba(47, 42, 68, 0.1);
    padding: clamp(24px, 5vw, 54px);
    overflow: visible;
    position: relative;
    isolation: isolate;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background:
      linear-gradient(105deg, rgba(255, 255, 255, 0.92) 0%, rgba(255, 255, 255, 0.78) 40%, rgba(255, 255, 255, 0.48) 72%, rgba(255, 255, 255, 0.35) 100%),
      url('/assets/hero-garden.webp') right center / auto 100% no-repeat;
    z-index: 0;
    pointer-events: none;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0px, black 50px, black calc(100% - 50px), transparent 100%);
    mask-image: linear-gradient(to bottom, transparent 0px, black 50px, black calc(100% - 50px), transparent 100%);
  }

  .hero > *:not(.panel-hanger) {
    position: relative;
    z-index: 2;
  }

  .panel-hanger {
    position: absolute;
    top: 26px;
    right: 10px;
    width: 164px;
    height: 152px;
    z-index: 12;
    --swing-angle: 0.17rad;
    --thread-length: 48px;
    --card-tilt: -0.06rad;
    --hanger-axis: 112px;
  }

  .panel-pin {
    position: absolute;
    top: 10px;
    left: calc(var(--hanger-axis) - 5px);
    width: 10px;
    height: 10px;
    border: 2px solid rgba(47, 42, 68, 0.28);
    border-radius: 50%;
    background: var(--secondary);
    box-shadow: 0 2px 0 rgba(47, 42, 68, 0.15);
  }

  .panel-arm {
    position: absolute;
    top: 16px;
    left: var(--hanger-axis);
    width: 0;
    transform-origin: top center;
    transform: rotate(var(--swing-angle));
    pointer-events: none;
  }

  .panel-thread {
    display: block;
    width: 2px;
    margin-left: -1px;
    height: var(--thread-length);
    background: rgba(47, 42, 68, 0.45);
  }

  .panel-tag {
    position: absolute;
    left: 0;
    top: var(--thread-length);
    transform: translateX(-50%) rotate(var(--card-tilt));
    transform-origin: top center;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    width: 86px;
    border: 2px solid rgba(47, 42, 68, 0.26);
    border-radius: 12px 12px 16px 16px;
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.97), rgba(255, 255, 255, 0.88));
    box-shadow: 0 8px 14px rgba(47, 42, 68, 0.16);
    padding: 8px 10px 10px;
    font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 12px;
    color: rgba(47, 42, 68, 0.86);
    text-align: center;
    z-index: 1;
    pointer-events: auto;
    cursor: grab;
    touch-action: none;
    user-select: none;
  }

  .panel-tag-label {
    display: block;
    font-size: 11px;
    letter-spacing: 0.1em;
    line-height: 1;
    opacity: 0.82;
    text-transform: uppercase;
  }

  .panel-tag-value {
    display: block;
    margin-top: 2px;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1;
    color: var(--primary-text);
  }

  .title {
    font-family: var(--font-heading);
    font-size: clamp(38px, 8vw, 72px);
    line-height: 1;
    letter-spacing: 0.01em;
    margin-bottom: 14px;
  }

  .title .swirl {
    color: var(--primary-text);
  }

  .subtitle {
    max-width: 680px;
    font-size: clamp(18px, 2.8vw, 26px);
    line-height: 1.2;
    color: var(--muted);
    margin-bottom: 24px;
  }

  .hero-mobile-cta {
    display: none;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    margin-top: 20px;
  }

  .command-card {
    border: 2px solid rgba(47, 42, 68, 0.2);
    border-radius: 20px;
    background: var(--paper);
    overflow: hidden;
    max-width: 700px;
  }

  .command-head {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    position: relative;
    background: var(--mint-soft);
    border-bottom: 2px solid rgba(47, 42, 68, 0.14);
    padding: 10px 14px;
  }

  .command-title {
    font-family: var(--font-heading);
    font-size: 19px;
    font-weight: 600;
  }

  .command-body {
    font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: clamp(14px, 2.1vw, 18px);
    padding: 16px;
    display: flex;
    flex-wrap: nowrap;
    gap: 10px;
    align-items: center;
    justify-content: flex-start;
    overflow-x: auto;
  }

  .prompt {
    color: var(--primary-text);
  }

  .cmd {
    color: var(--ink);
    min-height: 1.2em;
    white-space: nowrap;
    flex: 0 0 auto;
  }

  .cursor {
    width: 8px;
    height: 18px;
    background: var(--ink);
    animation: blink 1s steps(1, end) infinite;
    flex: 0 0 auto;
  }

  .command-actions {
    display: flex;
    flex-wrap: nowrap;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    padding: 0 16px 16px;
  }

  .command-selector {
    display: inline-flex;
    border: 2px solid rgba(47, 42, 68, 0.22);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.78);
    overflow: hidden;
    margin-left: auto;
  }

  .command-mode {
    border: 0;
    background: transparent;
    color: rgba(47, 42, 68, 0.72);
    padding: 7px 12px;
    font-family: "Nunito", sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: lowercase;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .command-mode.is-active {
    background: rgba(232, 135, 131, 0.28);
    color: rgba(47, 42, 68, 0.95);
  }

  .btn {
    border: 1.5px solid rgba(232, 135, 131, 0.4);
    border-radius: 999px;
    background: rgba(232, 135, 131, 0.2);
    color: var(--ink);
    padding: 8px 18px;
    font-family: "Nunito", sans-serif;
    font-size: 16px;
    font-weight: 700;
    line-height: 1;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
  }

  .btn:hover {
    transform: translateY(-1px);
    background: rgba(232, 135, 131, 0.32);
    border-color: rgba(232, 135, 131, 0.55);
  }

  .btn:focus-visible,
  .command-mode:focus-visible,
  .copy-inline:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }

  .copy-inline {
    width: 44px;
    height: 44px;
    margin-left: auto;
    border: 2px solid rgba(47, 42, 68, 0.26);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.86);
    color: var(--ink);
    cursor: pointer;
    flex: 0 0 auto;
    transition: transform 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }

  .copy-inline:hover {
    transform: translateY(-1px);
  }

  .copy-inline .copy-button-icon {
    width: 17px;
    height: 17px;
  }

  .copy-inline.is-copied {
    background: rgba(155, 196, 182, 0.24);
    border-color: rgba(155, 196, 182, 0.58);
    color: rgba(22, 110, 80, 0.95);
  }

  /* Shared section header */
  .hero-block-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
  }

  .hero-block-label {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: rgba(47, 42, 68, 0.9);
  }

  .hero-block-rule {
    flex: 1;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(232, 135, 131, 0.35), rgba(155, 196, 182, 0.25), transparent);
  }

  /* Workflow section */
  .workflow-section {
    margin-top: 32px;
  }

  .workflow-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    list-style: none;
    padding: 0;
  }

  .workflow-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 4px;
    padding: 16px;
    text-decoration: none;
  }

  .workflow-visual {
    position: relative;
    width: 140px;
    height: 140px;
    margin: 0 auto 8px;
    isolation: isolate;
  }

  .workflow-orb {
    position: absolute;
    top: -4px;
    left: -4px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 700;
    color: white;
    z-index: 1;
    box-shadow: 0 2px 6px rgba(47, 42, 68, 0.15);
  }

  .workflow-orb-1 { background: var(--primary); }
  .workflow-orb-2 { background: var(--secondary); }
  .workflow-orb-3 { background: var(--gold); }

  .workflow-img {
    width: 140px;
    height: 140px;
    object-fit: contain;
    display: block;
    transition: transform 0.2s ease;
  }

  .workflow-visual::after {
    content: "";
    position: absolute;
    inset: 15%;
    border-radius: 50%;
    background: rgba(232, 135, 131, 0.12);
    filter: blur(16px);
    z-index: -1;
  }

  .workflow-step:nth-child(2) .workflow-visual::after {
    background: rgba(155, 196, 182, 0.14);
  }

  .workflow-step:nth-child(3) .workflow-visual::after {
    background: rgba(214, 166, 62, 0.12);
  }

  .workflow-link:hover {
    background: rgba(232, 135, 131, 0.06);
    border-radius: 14px;
  }

  .workflow-link:hover .workflow-cmd {
    color: var(--accent);
  }

  .workflow-link:hover .workflow-img {
    transform: scale(1.15);
  }

  .workflow-link:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
    border-radius: 14px;
  }

  .workflow-cmd {
    font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 16px;
    font-weight: 700;
    color: var(--ink);
    background: none;
    padding: 0;
    transition: color 0.15s ease;
  }

  .workflow-desc {
    font-size: 14px;
    line-height: 1.35;
    color: var(--muted);
  }

  .cta-link:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }

  /* Features section */
  .features-section {
    margin-top: 28px;
  }

  .feature-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
  }

  .feature-link {
    display: block;
    text-decoration: none;
    padding: 14px 16px;
    border-radius: 14px;
    transition: background 0.15s ease;
  }

  .feature-link:hover {
    background: rgba(232, 135, 131, 0.08);
  }

  .feature-link:hover .feature-link-title {
    color: var(--accent);
  }

  .feature-link:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }

  .feature-link-title {
    display: block;
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.2;
    transition: color 0.15s ease;
  }

  .feature-link-desc {
    display: block;
    font-size: 14px;
    line-height: 1.35;
    color: var(--muted);
    margin-top: 2px;
  }

  .feature-link-desc code {
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 0.9em;
    padding: 1px 4px;
    border-radius: 4px;
    background: rgba(47, 42, 68, 0.06);
    color: var(--ink);
  }

  /* CTA section */
  .cta-section {
    margin-top: 32px;
    text-align: center;
    padding: 48px 0 24px;
  }

  .cta-text {
    font-family: var(--font-heading);
    font-size: clamp(18px, 3vw, 22px);
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 16px;
  }

  .cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .cta-btn {
    padding: 10px 24px;
    font-size: 17px;
  }

  .cta-link {
    font-family: "Nunito", sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
    opacity: 0.7;
    transition: color 0.15s ease;
  }

  .cta-link:hover {
    color: var(--accent);
  }

  @keyframes blink {
    0%,
    50% { opacity: 1; }
    51%,
    100% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor { animation: none; }
    .feature-link,
    .feature-link-title,
    .workflow-cmd,
    .workflow-img,
    .btn,
    .copy-inline,
    .command-mode,
    .cta-link { transition: none; }
  }

  @media (max-width: 900px) {
    .panel-hanger {
      right: 8px;
      top: 20px;
      transform: scale(0.9);
      transform-origin: top right;
    }
  }

  @media (max-width: 640px) {
    .panel-hanger {
      right: -8px;
      top: 10px;
      transform: scale(0.78);
      transform-origin: top right;
    }

    .subtitle {
      color: var(--ink);
    }

    .hero::before {
      background:
        linear-gradient(105deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.85) 50%, rgba(255, 255, 255, 0.5) 80%, rgba(255, 255, 255, 0.35) 100%),
        url('/assets/hero-garden.webp') right center / auto 100% no-repeat;
    }

    .command-card {
      display: none;
    }

    .hero-mobile-cta {
      display: flex;
    }

    .workflow-link {
      flex-direction: row;
      align-items: center;
      text-align: left;
      gap: 12px;
    }

    .workflow-cmd {
      min-width: 110px;
      flex-shrink: 0;
    }

    .workflow-visual {
      width: 56px;
      height: 56px;
      margin: 0;
      flex-shrink: 0;
    }

    .workflow-img {
      width: 56px;
      height: 56px;
    }

    .workflow-orb {
      width: 22px;
      height: 22px;
      font-size: 12px;
      top: -3px;
      left: -3px;
    }

    .workflow-visual::after {
      display: none;
    }

    .command-actions {
      flex-wrap: wrap;
      align-items: center;
    }

    .btn {
      padding: 10px 20px;
    }

    .command-mode {
      padding: 12px 14px;
    }

    .feature-list {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .workflow-steps {
      grid-template-columns: 1fr;
    }

    .workflow-section,
    .features-section {
      margin-top: 24px;
    }

    .hero-block-label {
      font-size: 16px;
    }

  }
</style>

<script type="module">
  const installCommands = {
    shell: "curl -fsSL https://tako.sh/install.sh | sh",
    cargo: "cargo install tako",
  };
  const typedCmd = document.getElementById("typed-cmd");
  const copyBtn = document.getElementById("copy");
  const copyBtnLabel = copyBtn?.querySelector("[data-copy-label]");
  const modeButtons = Array.from(document.querySelectorAll("[data-install-mode]"));
  const hanger = document.getElementById("mit-hanger");
  const pin = document.getElementById("mit-pin");
  const tag = document.getElementById("mit-tag");

  let activeInstallMode = "shell";
  let typingTimeout = null;

  const setCopyButtonText = (text) => {
    if (copyBtnLabel instanceof HTMLElement) {
      copyBtnLabel.textContent = text;
    }
    if (copyBtn instanceof HTMLElement) {
      copyBtn.setAttribute("aria-label", text);
      copyBtn.setAttribute("title", text);
    }
  };

  const setCopyButtonCopied = (copied) => {
    if (copyBtn instanceof HTMLElement) {
      copyBtn.classList.toggle("is-copied", copied);
    }
  };

  const writeCommand = (command, animate) => {
    if (!(typedCmd instanceof HTMLElement)) {
      return;
    }

    if (typeof typingTimeout === "number") {
      clearTimeout(typingTimeout);
      typingTimeout = null;
    }

    if (!animate) {
      typedCmd.textContent = command;
      return;
    }

    typedCmd.textContent = "";
    let i = 0;
    const writeChar = () => {
      if (!(typedCmd instanceof HTMLElement) || i >= command.length) {
        return;
      }
      typedCmd.textContent += command.charAt(i);
      i += 1;
      typingTimeout = window.setTimeout(writeChar, 35 + Math.random() * 28);
    };
    typingTimeout = window.setTimeout(writeChar, 620);
  };

  const setInstallMode = (mode, animate) => {
    if (!(mode in installCommands)) {
      return;
    }
    activeInstallMode = mode;
    for (const modeButton of modeButtons) {
      if (!(modeButton instanceof HTMLElement)) {
        continue;
      }
      const selected = modeButton.dataset.installMode === mode;
      modeButton.classList.toggle("is-active", selected);
      modeButton.setAttribute("aria-pressed", selected ? "true" : "false");
    }
    writeCommand(installCommands[mode], animate);
    setCopyButtonCopied(false);
    setCopyButtonText("copy install command");
  };

  setInstallMode("shell", true);

  for (const modeButton of modeButtons) {
    modeButton?.addEventListener("click", () => {
      const mode = modeButton.dataset.installMode ?? "shell";
      setInstallMode(mode, false);
    });
  }

  copyBtn?.addEventListener("click", async () => {
    try {
      await navigator.clipboard.writeText(installCommands[activeInstallMode] ?? installCommands.shell);
      setCopyButtonCopied(true);
      setCopyButtonText("copied");
      setTimeout(() => {
        setCopyButtonCopied(false);
        setCopyButtonText("copy install command");
      }, 1400);
    } catch {
      setCopyButtonCopied(false);
      setCopyButtonText("copy failed");
      setTimeout(() => {
        setCopyButtonText("copy install command");
      }, 1400);
    }
  });

  if (hanger instanceof HTMLElement && pin instanceof HTMLElement && tag instanceof HTMLElement) {
    const restAngle = 0;
    const isCompactScreen = window.matchMedia("(max-width: 640px)").matches;
    const restLength = isCompactScreen ? 54 : 62;
    const minLength = 30;
    const maxLength = 220;
    let angle = -0.42;
    let angularVelocity = 1.1;
    let length = restLength * 0.5;
    let lengthVelocity = 210;
    let dragging = false;
    let animating = false;
    const gravity = 1200;
    const angularDamping = 2.8;
    const angleSpring = 2.2;
    const lengthSpring = 19;
    const posePrecision = {
      angle: 0.001,
      length: 1,
      tilt: 0.001,
    };
    const settleThreshold = {
      angle: 0.002,
      angularVelocity: 0.02,
      length: 0.2,
      lengthVelocity: 2,
    };
    const lastPose = {
      angle: Number.NaN,
      length: Number.NaN,
      tilt: Number.NaN,
    };

    let lastFrame = performance.now();
    let dragSampleTime = lastFrame;
    let dragAngleSample = angle;
    let dragLengthSample = length;

    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
    const quantize = (value, step) => Math.round(value / step) * step;
    const formatRad = (value) => value.toFixed(3);
    const isNearRest = () => {
      return (
        Math.abs(angle - restAngle) < settleThreshold.angle &&
        Math.abs(angularVelocity) < settleThreshold.angularVelocity &&
        Math.abs(length - restLength) < settleThreshold.length &&
        Math.abs(lengthVelocity) < settleThreshold.lengthVelocity
      );
    };

    const applyPose = () => {
      const nextAngle = quantize(angle, posePrecision.angle);
      const nextLength = quantize(length, posePrecision.length);
      const nextTilt = quantize(-angle * 0.36, posePrecision.tilt);

      if (nextAngle !== lastPose.angle) {
        hanger.style.setProperty("--swing-angle", `${formatRad(nextAngle)}rad`);
        lastPose.angle = nextAngle;
      }
      if (nextLength !== lastPose.length) {
        hanger.style.setProperty("--thread-length", `${nextLength}px`);
        lastPose.length = nextLength;
      }
      if (nextTilt !== lastPose.tilt) {
        hanger.style.setProperty("--card-tilt", `${formatRad(nextTilt)}rad`);
        lastPose.tilt = nextTilt;
      }
    };

    const setFromPointer = (x, y) => {
      const rect = pin.getBoundingClientRect();
      const anchorX = rect.left + rect.width / 2;
      const anchorY = rect.top + rect.height / 2;
      const dx = x - anchorX;
      const dy = y - anchorY;
      angle = -Math.atan2(dx, dy);
      length = clamp(Math.hypot(dx, dy), minLength, maxLength);
    };

    const endDrag = (pointerId) => {
      if (!dragging) {
        return;
      }
      dragging = false;
      if (typeof pointerId === "number" && tag.hasPointerCapture(pointerId)) {
        tag.releasePointerCapture(pointerId);
      }
      angularVelocity = clamp(angularVelocity, -7.5, 7.5);
      lengthVelocity = clamp(lengthVelocity, -220, 220);
      tag.style.cursor = "grab";
      document.body.style.userSelect = "";
    };

    const startAnimation = () => {
      if (!animating && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        animating = true;
        lastFrame = performance.now();
        requestAnimationFrame(tick);
      }
    };

    tag.addEventListener("pointerdown", (event) => {
      dragging = true;
      tag.setPointerCapture(event.pointerId);
      angularVelocity = 0;
      lengthVelocity = 0;
      setFromPointer(event.clientX, event.clientY);
      dragSampleTime = performance.now();
      dragAngleSample = angle;
      dragLengthSample = length;
      applyPose();
      startAnimation();
      tag.style.cursor = "grabbing";
      document.body.style.userSelect = "none";
    });

    tag.addEventListener("pointermove", (event) => {
      if (!dragging) {
        return;
      }
      setFromPointer(event.clientX, event.clientY);
      const now = performance.now();
      const dt = Math.max((now - dragSampleTime) / 1000, 1 / 240);
      angularVelocity = (angle - dragAngleSample) / dt;
      lengthVelocity = (length - dragLengthSample) / dt;
      dragSampleTime = now;
      dragAngleSample = angle;
      dragLengthSample = length;
      applyPose();
    });

    tag.addEventListener("pointerup", (event) => {
      endDrag(event.pointerId);
    });

    tag.addEventListener("pointercancel", (event) => {
      endDrag(event.pointerId);
    });

    tag.addEventListener("lostpointercapture", () => {
      dragging = false;
      tag.style.cursor = "grab";
      document.body.style.userSelect = "";
    });

    const tick = (now) => {
      const dt = Math.min((now - lastFrame) / 1000, 0.033);
      lastFrame = now;

      if (!dragging) {
        // Let the hanger fully settle by removing breeze in the near-rest band.
        const breeze = isNearRest() ? 0 : Math.sin(now * 0.0017) * 0.18 + Math.sin(now * 0.00061) * 0.08;
        const gravityForce = -(gravity / Math.max(length, 1)) * Math.sin(angle);
        const springForce = (restAngle - angle) * angleSpring;
        angularVelocity += (gravityForce + springForce + breeze - angularVelocity * angularDamping) * dt;
        angle += angularVelocity * dt;

        lengthVelocity += (restLength - length) * lengthSpring * dt;
        lengthVelocity *= Math.exp(-5.0 * dt);
        length += lengthVelocity * dt;
        length = clamp(length, minLength, maxLength);

        if (isNearRest()) {
          angle = restAngle;
          angularVelocity = 0;
          length = restLength;
          lengthVelocity = 0;
        }
      }

      applyPose();

      if (!dragging && isNearRest()) {
        animating = false;
      } else {
        requestAnimationFrame(tick);
      }
    };

    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reducedMotion) {
      angle = restAngle;
      length = restLength;
      applyPose();
    } else {
      applyPose();
      animating = true;
      requestAnimationFrame(tick);
    }
  }
</script>
