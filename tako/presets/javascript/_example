# Preset family definitions.
# Each section defines a named preset for this language.
# Presets provide main entrypoint and assets defaults for specific frameworks.
# Use in tako.toml as: preset = "my-preset" (with runtime set).
# See javascript.toml for a complete working example.

# [my-preset]
# main = "dist/server/tako-entry.mjs"     # Default main entrypoint for this framework.
# assets = ["dist/client"]                 # Static asset dirs merged into deploy artifact.
